1st Solution :

var merge = function(nums1, m, nums2, n) {
    let p1 = m - 1;
    let p2 = n - 1
    for(let i = m + n -1; i >=0; i--){
        if(p2 < 0) break;
        if(p1 >= 0 && nums1[p1] > nums2[p2]){
        nums1[i] = nums1[p1];
        p1--;
    } else {
        nums1[i] = nums2[p2];
        p2--;
    }
    }
};

2nd Solution:

var merge = function(nums1, m, nums2, n) {
    for (let i = m; i < nums1.length; i++) {
      nums1[i] = nums2[i - m];
    }
    nums1.sort((a, b) => a - b);
  }; 
